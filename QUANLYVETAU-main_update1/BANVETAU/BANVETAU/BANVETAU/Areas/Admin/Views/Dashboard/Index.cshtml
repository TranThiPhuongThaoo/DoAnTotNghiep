
@{
    ViewBag.Title = "DashBoard";
    Layout = "~/Areas/Admin/Views/Shared/_layOutAdmin.cshtml";
}
<!-- Content Wrapper. Contains page content -->
<div class="card card-title bg-white p-1 container">
    <div class="row">
        <div class="col-md-6 "> <h5 class="pl-2 mt-2 text-blues">Trang quản trị</h5> </div>
    </div>
</div>

<section class="pt-2 container card">
    @Html.Partial("_MessgeAlert")
    <div class="bg-white p-4">
        <div class="row justify-content-md-start">
            <div class="col-4 col-sm-6 col-md-4 rounded p-2" style="background-color: #405163; height: 70px;">
                <span style="color: #D7D5DC">Tổng doanh thu dự tính</span>
                <span class="w-100 justify-content-center ml-2"style="color: #D7D5DC; font-size:x-large; display: block;">@ViewBag.Revenue USD</span>
            </div>
        </div>
    </div>
</section>
<script>$("#user").addClass("active");</script>
